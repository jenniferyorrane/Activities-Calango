algoritmo somaMultiplos15;

principal
    inteiro soma;
    inteiro i;

    soma = 0;
    
    // Varre o intervalo testando quem é múltiplo de 15
    para (i de 1 ate 500 passo 1) faca
        se ((i % 15) == 0) entao
            soma = soma + i;
        fimSe     
    fimPara

    escreval("O valor da soma dos multiplos de 15 entre 1 e 500 = ", soma);
fimPrincipal
